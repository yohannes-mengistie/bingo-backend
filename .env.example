# Copy to .env and fill in your own values.
#
# Anything marked PRODUCTION must be changed before deploying — the defaults
# below are only safe for local development.

# ---- Server ----
PORT=8000                 # Railway/Render set this automatically; SERVER_PORT also accepted
SERVER_HOST=0.0.0.0

# ---- Database (PostgreSQL) ----
# Local Docker uses the service name "postgres". For a managed DB, set these to
# your provider's host/credentials and set DB_SSLMODE=require.
# (PG* equivalents — PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE/PGSSLMODE — also work.)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres      # PRODUCTION: use a strong password
DB_NAME=bingo
DB_SSLMODE=disable        # PRODUCTION: require

# ---- Redis ----
# Either set REDIS_URL (e.g. redis://:password@host:6379/0) OR the fields below.
# REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Auth ----
# REQUIRED: must be >=32 chars and NOT the placeholder, or the server refuses to
# start. Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRATION_HOURS=24
SECRET_CODE=change-me                 # PRODUCTION: secret that gates POST /auth/create-admin

# ---- Internal service auth ----
# Shared secret for the bot-facing /user, /wallet and per-user /games endpoints.
# Callers send it in the X-Internal-Api-Secret header. Leave blank to DISABLE
# those endpoints (they expose other users' data and must never be public).
INTERNAL_API_SECRET=

# ---- Telegram ----
# Bot token from @BotFather. Required to verify Mini App initData on
# POST /api/v1/auth/telegram. PRODUCTION: keep secret.
TELEGRAM_BOT_TOKEN=

# ---- Filler bots (house-funded players that fill empty games) ----
# Master switch for the background auto-filler goroutine. The fill POLICY itself
# (on/off, thresholds, target count) lives in the DB and is edited from the admin
# dashboard (admin/bots/config); this only decides whether the machinery runs.
BOTS_ENABLED=false
BOT_POOL_SIZE=30                  # how many bot accounts to seed on boot
BOT_WALLET_FLOAT=1000             # birr each bot wallet is topped up to (house bankroll)
BOT_MAX_JOINS_PER_TICK=5          # bots added per game per sweep (spaces joins out)
BOT_CHECK_INTERVAL_SECONDS=1      # seconds between auto-fill sweeps
# Fill rate is MAX_JOINS_PER_TICK per CHECK_INTERVAL_SECONDS — 5/sec at these
# values, so a target of 100 bots lands in ~20s. Mind the ceiling: bots join
# via the same path as humans, so the FIRST bot to enter a 1-real-player game
# becomes distinct player #2 and starts the 40s countdown (CountdownDuration,
# internal/domain/constants.go:14) on itself. That leaves ~40 ticks, i.e. a
# hard cap of ~200 bots per game at 5/sec — a higher bot_config.target_bots
# than that is silently unreachable, not slower.

# ---- Rate limiting ----
# Each bucket is "<n> requests per <window> seconds". Set a limit to 0 to
# disable that bucket without a deploy.
#
# The auth buckets are keyed per-IP (there is no user yet) and are deliberately
# loose: Ethiopian mobile carriers put many subscribers behind one NAT address,
# so a tight per-IP limit would lock out a whole carrier. The money buckets sit
# behind auth and key on the USER id, so they can be tight without that risk.
RL_LOGIN_LIMIT=50                 # admin password login, per IP
RL_LOGIN_WINDOW_SECONDS=900
RL_CREATE_ADMIN_LIMIT=5           # secret-code gated admin creation, per IP
RL_CREATE_ADMIN_WINDOW_SECONDS=3600
RL_TELEGRAM_AUTH_LIMIT=300        # Mini App initData -> JWT, per IP (every app open)
RL_TELEGRAM_AUTH_WINDOW_SECONDS=60
RL_DEPOSIT_LIMIT=10               # per USER
RL_DEPOSIT_WINDOW_SECONDS=60
RL_WITHDRAW_LIMIT=5               # per USER
RL_WITHDRAW_WINDOW_SECONDS=60
RL_TRANSFER_LIMIT=10              # per USER
RL_TRANSFER_WINDOW_SECONDS=60
RL_WEBSOCKET_LIMIT=300            # socket connection attempts, per IP
RL_WEBSOCKET_WINDOW_SECONDS=60

# Networks a reverse proxy may reach this service from, comma-separated CIDRs.
# This decides what c.ClientIP() returns and therefore whether the per-IP rate
# limits mean anything: without it gin trusts every proxy and reads a
# caller-controlled X-Forwarded-For, so limits are bypassed by rotating that
# header. Default covers private + CGNAT ranges; override only if the platform
# edge reaches containers from somewhere else.
# TRUSTED_PROXIES=10.0.0.0/8,fd00::/8

# Seconds to hold bots back after the FIRST real player joins a game, before
# any bot may enter. Without it the sweeper fills the moment someone sits down,
# so a player watches five strangers arrive within a second of picking their
# card. Jittered per game (actual wait is delay..delay*1.5) because a fixed
# pause is itself a pattern to anyone who plays a few rounds. 0 disables it.
# Note this adds to the wait before a round starts: the 40s countdown only
# begins once the first bot arrives and becomes distinct player #2.
BOT_JOIN_DELAY_SECONDS=5

# Probability that bots win when they hold a valid bingo alongside human winners.
# 0.0 = humans always win co-winner situations, 1.0 = bots always win.
# The admin dashboard can also override this live (admin/bots/config).
BOT_WIN_RATE=0.8
