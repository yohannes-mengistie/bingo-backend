# Copy to .env and fill in your own values.
#
# Anything marked PRODUCTION must be changed before deploying — the defaults
# below are only safe for local development.

# ---- Server ----
PORT=8000                 # Railway/Render set this automatically; SERVER_PORT also accepted
SERVER_HOST=0.0.0.0

# ---- Database (PostgreSQL) ----
# Local Docker uses the service name "postgres". For a managed DB, set these to
# your provider's host/credentials and set DB_SSLMODE=require.
# (PG* equivalents — PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE/PGSSLMODE — also work.)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres      # PRODUCTION: use a strong password
DB_NAME=bingo
DB_SSLMODE=disable        # PRODUCTION: require

# ---- Redis ----
# Either set REDIS_URL (e.g. redis://:password@host:6379/0) OR the fields below.
# REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Auth ----
# REQUIRED: must be >=32 chars and NOT the placeholder, or the server refuses to
# start. Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRATION_HOURS=24
SECRET_CODE=change-me                 # PRODUCTION: secret that gates POST /auth/create-admin

# ---- Internal service auth ----
# Shared secret for the bot-facing /user, /wallet and per-user /games endpoints.
# Callers send it in the X-Internal-Api-Secret header. Leave blank to DISABLE
# those endpoints (they expose other users' data and must never be public).
INTERNAL_API_SECRET=

# ---- Telegram ----
# Bot token from @BotFather. Required to verify Mini App initData on
# POST /api/v1/auth/telegram. PRODUCTION: keep secret.
TELEGRAM_BOT_TOKEN=

# ---- Filler bots (house-funded players that fill empty games) ----
# Master switch for the background auto-filler goroutine. The fill POLICY itself
# (on/off, thresholds, target count) lives in the DB and is edited from the admin
# dashboard (admin/bots/config); this only decides whether the machinery runs.
BOTS_ENABLED=false
BOT_POOL_SIZE=30                  # how many bot accounts to seed on boot
BOT_WALLET_FLOAT=1000             # birr each bot wallet is topped up to (house bankroll)
BOT_MAX_JOINS_PER_TICK=5          # bots added per game per sweep (spaces joins out)
BOT_CHECK_INTERVAL_SECONDS=5      # seconds between auto-fill sweeps
